@ECHO OFF

REM MS-DOS GAME LAUNCHER BY BRYAN C.

REM DETERMINE HOW THE USER LAUNCHED THIS SCRIPT AND
REM ADD FILE EXTENSION IF MISSING FOR SECRET MENU (0)

IF EXIST %0.BAT GOTO ADD_EXTENSION
GOTO HAS_EXTENSION

:ADD_EXTENSION
SET SCRIPTNAME=%0.BAT
GOTO MENU_MAIN

:HAS_EXTENSION
SET SCRIPTNAME=%0
GOTO MENU_MAIN

:MENU_MAIN
CLS
ECHO.
ECHO  =======================
ECHO         MAIN MENU
ECHO  =======================
ECHO.
ECHO    A) DOOM
ECHO    B) DOOM II
ECHO    C) FASTDOOM
ECHO    D) Quake
ECHO  + E) Duke Nukem 1
ECHO    F) Duke Nukem 2
ECHO    G) Duke Nukem 3D
ECHO    H) Dark Forces
ECHO    I) SC2000
ECHO  + J) Lemmings
ECHO    K) Oregon Trail
ECHO    L) Wolfenstein 3D
ECHO  + S) Shareware
ECHO    R) Return to DOS Prompt
ECHO.
CHOICE /C:ABCDEFGHIJKLSR0 /N " Make a selection: "

IF ERRORLEVEL 15 GOTO MENU_SECRET
IF ERRORLEVEL 14 GOTO END
IF ERRORLEVEL 13 GOTO MENU_SHARE
IF ERRORLEVEL 12 GOTO WOLF3D
IF ERRORLEVEL 11 GOTO OREGON
IF ERRORLEVEL 10 GOTO MENU_LEMM
IF ERRORLEVEL 9 GOTO SC2000
IF ERRORLEVEL 8 GOTO DARK
IF ERRORLEVEL 7 GOTO DUKE3D
IF ERRORLEVEL 6 GOTO DUKE2
IF ERRORLEVEL 5 GOTO MENU_DUKE1
IF ERRORLEVEL 4 GOTO QUAKE
IF ERRORLEVEL 3 GOTO FDOOM
IF ERRORLEVEL 2 GOTO DOOM2
IF ERRORLEVEL 1 GOTO DOOM_SE

:MENU_DUKE1
CLS
ECHO.
ECHO  =======================
ECHO       DUKE NUKEM 1
ECHO  =======================
ECHO.
ECHO    A) Episode 1
ECHO    B) Episode 2
ECHO    C) Episode 3
ECHO    R) Return to Main Menu
ECHO.
CHOICE /C:ABCR /N " Make a selection: "

IF ERRORLEVEL 4 GOTO MENU_MAIN
IF ERRORLEVEL 3 GOTO DUKE1_EP3
IF ERRORLEVEL 2 GOTO DUKE1_EP2
IF ERRORLEVEL 1 GOTO DUKE1_EP1

:MENU_LEMM
CLS
ECHO.
ECHO  =======================
ECHO         LEMMINGS
ECHO  =======================
ECHO.
ECHO    A) Lemmings
ECHO    B) Oh No! More Lemmings
ECHO    R) Return to Main Menu
ECHO.
CHOICE /C:ABR /N " Make a selection: "

IF ERRORLEVEL 3 GOTO MENU_MAIN
IF ERRORLEVEL 2 GOTO LEMM_OHNO
IF ERRORLEVEL 1 GOTO LEMMINGS

:MENU_SHARE
CLS
ECHO.
ECHO  =======================
ECHO         SHAREWARE
ECHO  =======================
ECHO.
ECHO    A) Raptor
ECHO    B) Heretic
ECHO    C) Wacky Wheels
ECHO    R) Return to Main Menu
ECHO.
CHOICE /C:ABCR /N " Make a selection: "

IF ERRORLEVEL 4 GOTO MENU_MAIN
IF ERRORLEVEL 3 GOTO WWHEELS
IF ERRORLEVEL 2 GOTO HERETIC
IF ERRORLEVEL 1 GOTO RAPTOR

:MENU_SECRET
CLS
ECHO.
ECHO  Super secret EDIT mode found!
ECHO.
CHOICE /C:YN /N " Would you like to edit this batch file? (Y/N): "

IF ERRORLEVEL 2 GOTO MENU_MAIN
IF ERRORLEVEL 1 GOTO BACKUP_CHECK

:BACKUP_CHECK
SET BACKNAME=%SCRIPTNAME%1
IF NOT EXIST %BACKNAME% GOTO BACKUP
SET BACKNAME=%SCRIPTNAME%2
GOTO BACKUP

:BACKUP
ECHO.
ECHO  Copying %SCRIPTNAME% to %BACKNAME%
COPY %SCRIPTNAME% %BACKNAME%
ECHO.
ECHO  Backup created: %BACKNAME%
ECHO.
PAUSE
GOTO EDIT

:EDIT
EDIT %SCRIPTNAME%
GOTO MENU_MAIN

